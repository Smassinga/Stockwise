# Brevo transactional email relay for Supabase Edge Functions.
# Keep these values in local untracked env files or in Supabase/Vercel secret stores.
# Use the dedicated Brevo SMTP login + SMTP key for relay auth. Do not use a Brevo API key as the SMTP password.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SENDER_EMAIL=no-reply@stockwiseapp.com
BREVO_SENDER_NAME=StockWise
BREVO_REPLY_TO_EMAIL=
BREVO_REPLY_TO_NAME=StockWise
MAILER_ALLOWED_ORIGINS=https://stockwiseapp.com

# Optional only if a future Brevo HTTP API sender is introduced.
# Current repo mail delivery does not use BREVO_API_KEY.
# BREVO_API_KEY=
