    "templates":  {
                      "confirmation":  {
                                           "subject":  "Welcome to Stockwise - Confirm your email",
                                           "content":  "\u003c!-- Stockwise Auth Email (bulletproof + Outlook-safe) --\u003e\n\u003c!-- Works for Confirmation/Magic/Reset (.ConfirmationURL) and Invites (.ActionURL) --\u003e\n\u003c!-- Link chooser: if ConfirmationURL exists use it; else fall back to ActionURL --\u003e\n{{- $URL := \"\" -}}\n{{- if .ConfirmationURL -}}\n  {{- $URL = .ConfirmationURL -}}\n{{- else if .ActionURL -}}\n  {{- $URL = .ActionURL -}}\n{{- end -}}\n\n\u003cdiv style=\"font-family: ui-sans-serif, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; color:#111827; line-height:1.5; background:#ffffff; margin:0; padding:0;\"\u003e\n  \u003cdiv style=\"max-width:640px;margin:0 auto;padding:24px;\"\u003e\n    \u003ch2 style=\"margin:0 0 8px; font-size:22px; line-height:1.25;\"\u003e\n      Welcome to \u003cspan style=\"color:#2563eb;\"\u003eStockwise\u003c/span\u003e 👋\n    \u003c/h2\u003e\n\n    \u003cp style=\"margin:0 0 16px;\"\u003e\n      Please confirm your email to finish setting up your account.\n    \u003c/p\u003e\n\n    \u003c!-- Bulletproof button --\u003e\n    \u003ctable role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"margin:0 0 20px;\"\u003e\n      \u003ctr\u003e\n        \u003ctd align=\"left\"\u003e\n          \u003c!--[if mso]\u003e\n          \u003cv:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" href=\"{{$URL}}\" style=\"height:44px;v-text-anchor:middle;width:230px;\" arcsize=\"12%\" stroke=\"f\" fillcolor=\"#2563eb\"\u003e\n            \u003cw:anchorlock/\u003e\n            \u003ccenter style=\"color:#ffffff;font-family:Segoe UI, Arial, sans-serif;font-size:16px;font-weight:700;\"\u003e\n              Confirm \u0026amp; Sign In\n            \u003c/center\u003e\n          \u003c/v:roundrect\u003e\n          \u003c![endif]--\u003e\n          \u003c!--[if !mso]\u003e\u003c!-- --\u003e\n          \u003ca href=\"{{$URL}}\" target=\"_blank\" rel=\"noopener noreferrer\"\n             style=\"display:inline-block;background:#2563eb;color:#ffffff;text-decoration:none;\n                    font-weight:700;font-size:16px;line-height:44px;border-radius:10px;\n                    padding:0 18px;min-width:230px;text-align:center;\"\u003e\n            Confirm \u0026amp; Sign In\n          \u003c/a\u003e\n          \u003c!--\u003c![endif]--\u003e\n        \u003c/td\u003e\n      \u003c/tr\u003e\n    \u003c/table\u003e\n\n    \u003cp style=\"margin:0 0 8px; color:#6b7280;\"\u003e\n      If the button doesn’t work, copy and paste this link into your browser:\n    \u003c/p\u003e\n    \u003cp style=\"word-break:break-all; margin:0 0 20px;\"\u003e\n      \u003ca href=\"{{$URL}}\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"color:#2563eb; text-decoration:underline;\"\u003e\n        {{$URL}}\n      \u003c/a\u003e\n    \u003c/p\u003e\n\n    \u003c!-- Trust \u0026 safety hints --\u003e\n    \u003cp style=\"margin:0 0 6px; font-size:12px; color:#6b7280;\"\u003e\n      This link is personal and may grant access to your account. Please don’t forward it.\n    \u003c/p\u003e\n    \u003cp style=\"margin:0 0 6px; font-size:12px; color:#6b7280;\"\u003e\n      Links may expire after a short time. If it expires, request a new one from the app.\n    \u003c/p\u003e\n\n    \u003cp style=\"margin:24px 0 0; font-size:12px; color:#6b7280;\"\u003e\n      If you didn’t create a Stockwise account, you can safely ignore this email.\n    \u003c/p\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n"
                                       },
                      "recovery":  {
                                       "subject":  "Reset your Stockwise password",
                                       "content":  "\u003cdiv style=\"font-family: ui-sans-serif, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; color:#111827; line-height:1.5;\"\u003e\n  \u003ch2 style=\"margin:0 0 8px; font-size:22px;\"\u003eReset your password\u003c/h2\u003e\n  \u003cp style=\"margin:0 0 16px;\"\u003eClick the button below to choose a new password for your Stockwise account.\u003c/p\u003e\n\n  \u003cp style=\"margin:0 0 20px;\"\u003e\n    \u003ca href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block; padding:12px 18px; border-radius:10px; background:#2563eb; color:#fff; text-decoration:none; font-weight:600;\"\u003eCreate New Password\u003c/a\u003e\n  \u003c/p\u003e\n\n  \u003cp style=\"margin:0 0 8px; color:#6b7280;\"\u003eOr paste this link into your browser:\u003c/p\u003e\n  \u003cp style=\"word-break:break-all; margin:0 0 20px;\"\u003e\u003ca href=\"{{ .ConfirmationURL }}\" style=\"color:#2563eb; text-decoration:underline;\"\u003e{{ .ConfirmationURL }}\u003c/a\u003e\u003c/p\u003e\n\n  \u003cp style=\"margin:24px 0 0; font-size:12px; color:#6b7280;\"\u003eIf you didn’t request a reset, you can ignore this email.\u003c/p\u003e\n\u003c/div\u003e\n"
                                   },
                      "invite":  {
                                     "subject":  "You’ve been invited to Stockwise",
                                     "content":  "\u003cdiv style=\"font-family: ui-sans-serif, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; color:#111827; line-height:1.5;\"\u003e\n  \u003ch2 style=\"margin:0 0 8px; font-size:22px;\"\u003eYou’re invited to \u003cspan style=\"color:#2563eb;\"\u003eStockwise\u003c/span\u003e\u003c/h2\u003e\n  \u003cp style=\"margin:0 0 16px;\"\u003eYou’ve been invited to join a workspace on {{ .SiteURL }}. Click below to accept the invitation and set up your access.\u003c/p\u003e\n\n  \u003cp style=\"margin:0 0 20px;\"\u003e\n    \u003ca href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block; padding:12px 18px; border-radius:10px; background:#2563eb; color:#fff; text-decoration:none; font-weight:600;\"\u003eAccept Invitation\u003c/a\u003e\n  \u003c/p\u003e\n\n  \u003cp style=\"margin:0 0 8px; color:#6b7280;\"\u003eHaving trouble? Use this link instead:\u003c/p\u003e\n  \u003cp style=\"word-break:break-all; margin:0 0 20px;\"\u003e\u003ca href=\"{{ .ConfirmationURL }}\" style=\"color:#2563eb; text-decoration:underline;\"\u003e{{ .ConfirmationURL }}\u003c/a\u003e\u003c/p\u003e\n\n  \u003cp style=\"margin:24px 0 0; font-size:12px; color:#6b7280;\"\u003eIf you weren’t expecting this invite, you can ignore this message.\u003c/p\u003e\n\u003c/div\u003e\n"
                                 },
                      "email_change":  {
                                           "subject":  "Confirm your new email for Stockwise",
                                           "content":  "\u003cdiv style=\"font-family: ui-sans-serif, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; color:#111827; line-height:1.5;\"\u003e\n  \u003ch2 style=\"margin:0 0 8px; font-size:22px;\"\u003eConfirm email change\u003c/h2\u003e\n  \u003cp style=\"margin:0 0 16px;\"\u003eYou requested to update your Stockwise email from \u003cstrong\u003e{{ .Email }}\u003c/strong\u003e to \u003cstrong\u003e{{ .NewEmail }}\u003c/strong\u003e. Please confirm below.\u003c/p\u003e\n\n  \u003cp style=\"margin:0 0 20px;\"\u003e\n    \u003ca href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block; padding:12px 18px; border-radius:10px; background:#2563eb; color:#fff; text-decoration:none; font-weight:600;\"\u003eConfirm New Email\u003c/a\u003e\n  \u003c/p\u003e\n\n  \u003cp style=\"margin:0 0 8px; color:#6b7280;\"\u003eIf the button doesn’t work, use this link:\u003c/p\u003e\n  \u003cp style=\"word-break:break-all; margin:0 0 20px;\"\u003e\u003ca href=\"{{ .ConfirmationURL }}\" style=\"color:#2563eb; text-decoration:underline;\"\u003e{{ .ConfirmationURL }}\u003c/a\u003e\u003c/p\u003e\n\n  \u003cp style=\"margin:24px 0 0; font-size:12px; color:#6b7280;\"\u003eDidn’t request this change? Secure your account by resetting your password.\u003c/p\u003e\n\u003c/div\u003e\n"
                                       },
                      "magic_link":  {
                                         "subject":  "Your Stockwise magic link",
                                         "content":  "\u003c!-- Stockwise Magic Link Email (polished + mobile/Outlook friendly) --\u003e\n\u003cdiv style=\"font-family: ui-sans-serif, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; color:#111827; line-height:1.5; background:#ffffff; margin:0; padding:0;\"\u003e\n  \u003c!-- Preheader (hidden preview text in inboxes) --\u003e\n  \u003cdiv style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\"\u003e\n    One-click sign in to Stockwise. This link expires soon.\n  \u003c/div\u003e\n\n  \u003cdiv style=\"max-width:640px;margin:0 auto;padding:24px;\"\u003e\n    \u003ch2 style=\"margin:0 0 8px; font-size:22px; line-height:1.25;\"\u003eOne-click sign in\u003c/h2\u003e\n    \u003cp style=\"margin:0 0 16px;\"\u003e\n      Use the magic link below to sign in to \u003cspan style=\"color:#2563eb;\"\u003eStockwise\u003c/span\u003e.\n    \u003c/p\u003e\n\n    \u003c!-- Bulletproof button (works in Outlook) --\u003e\n    \u003ctable role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"margin:0 0 20px;\"\u003e\n      \u003ctr\u003e\n        \u003ctd align=\"left\" style=\"border-radius:10px; background:#2563eb;\"\u003e\n          \u003ca\n            href=\"{{ .ConfirmationURL }}\"\n            style=\"\n              display:inline-block;\n              padding:12px 18px;\n              border-radius:10px;\n              background:#2563eb;\n              color:#ffffff;\n              text-decoration:none;\n              font-weight:600;\n              -webkit-text-size-adjust:100%;\n            \"\n          \u003e\n            Sign In\n          \u003c/a\u003e\n        \u003c/td\u003e\n      \u003c/tr\u003e\n    \u003c/table\u003e\n\n    \u003c!-- Plain link fallback (copyable) --\u003e\n    \u003cp style=\"margin:0 0 8px; color:#6b7280;\"\u003eOr paste this link into your browser:\u003c/p\u003e\n    \u003cp style=\"word-break:break-all; margin:0 0 20px;\"\u003e\n      \u003ca href=\"{{ .ConfirmationURL }}\" style=\"color:#2563eb; text-decoration:underline;\"\u003e{{ .ConfirmationURL }}\u003c/a\u003e\n    \u003c/p\u003e\n\n    \u003c!-- Safety / expectations --\u003e\n    \u003cp style=\"margin:24px 0 0; font-size:12px; color:#6b7280;\"\u003e\n      This link works once and expires soon. If you didn’t request it, you can safely ignore this email.\n    \u003c/p\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n"
                                     },
                      "reauthentication":  {
                                               "subject":  "Your Stockwise verification code",
                                               "content":  "\u003c!-- Stockwise OTP Email (polished + mobile/Outlook friendly) --\u003e\n\u003cdiv style=\"font-family: ui-sans-serif, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; color:#111827; line-height:1.5; background:#ffffff; margin:0; padding:0;\"\u003e\n  \u003c!-- Preheader (hidden preview text) --\u003e\n  \u003cdiv style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\"\u003e\n    Your verification code is {{ .Token }}.\n  \u003c/div\u003e\n\n  \u003cdiv style=\"max-width:640px;margin:0 auto;padding:24px;\"\u003e\n    \u003ch2 style=\"margin:0 0 8px; font-size:22px; line-height:1.25;\"\u003eVerify it’s you\u003c/h2\u003e\n    \u003cp style=\"margin:0 0 16px;\"\u003eUse this code to continue:\u003c/p\u003e\n\n    \u003c!-- Code block: large, copyable, accessible --\u003e\n    \u003ctable role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"margin:0 0 16px;\"\u003e\n      \u003ctr\u003e\n        \u003ctd\n          aria-label=\"One-time verification code\"\n          style=\"\n            font-size:28px;\n            font-weight:700;\n            letter-spacing:4px;\n            font-variant-numeric: tabular-nums;\n            background:#f3f4f6;\n            color:#111827;\n            padding:12px 16px;\n            border-radius:10px;\n            text-align:center;\n            -webkit-text-size-adjust:100%;\n            \"\u003e\n          \u003cspan style=\"font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \u0027Liberation Mono\u0027, \u0027Courier New\u0027, monospace;\"\u003e\n            {{ .Token }}\n          \u003c/span\u003e\n        \u003c/td\u003e\n      \u003c/tr\u003e\n    \u003c/table\u003e\n\n    \u003c!-- Hidden plain sentence helps iOS/Android autofill detect OTP --\u003e\n    \u003cdiv style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\"\u003e\n      Code: {{ .Token }}\n    \u003c/div\u003e\n\n    \u003c!-- Safety/expiry notes (keep generic if you don’t pass a TTL) --\u003e\n    \u003cp style=\"margin:0 0 4px; font-size:12px; color:#6b7280;\"\u003e\n      For your security, this code works only once and expires soon.\n    \u003c/p\u003e\n    \u003cp style=\"margin:0; font-size:12px; color:#6b7280;\"\u003e\n      If you didn’t try to sign in, you can safely ignore this email.\n    \u003c/p\u003e\n  \u003c/div\u003e\n\u003c/div\u003e\n"
                                           }
                  }
}
